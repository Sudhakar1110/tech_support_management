{
 "doctype": "Print Format",
 "name": "Service Report Print",
 "doc_type": "Service Report",
 "module": "TechCare",
 "print_format_type": "Jinja",
 "standard": "Yes",
 "disabled": 0,
 "html": "<div style=\"font-family: 'Helvetica Neue', Arial, sans-serif; color: #212529;\">\n  <div style=\"display: flex; justify-content: space-between; border-bottom: 3px solid #1971c2; padding-bottom: 12px;\">\n    <div>\n      <h1 style=\"margin: 0; color: #1971c2;\">Service Report</h1>\n      <p style=\"margin: 4px 0 0; color: #868e96;\">{{ doc.name }}</p>\n    </div>\n    <div style=\"text-align: right;\">\n      <p style=\"margin: 0;\"><strong>{{ frappe.defaults.get_global_default(\"company\") or \"\" }}</strong></p>\n      <p style=\"margin: 0; color: #868e96;\">{{ frappe.utils.format_date(doc.report_date) }}</p>\n    </div>\n  </div>\n  <table style=\"width: 100%; margin-top: 16px; font-size: 13px;\">\n    <tr>\n      <td style=\"width: 50%; vertical-align: top;\"><strong>Customer</strong><br>{{ doc.customer_name }}</td>\n      <td style=\"width: 50%; vertical-align: top;\"><strong>Device</strong><br>{{ frappe.db.get_value(\"Device\", doc.device, \"device_name\") }}<br>S/N: {{ frappe.db.get_value(\"Device\", doc.device, \"serial_number\") or \"&mdash;\" }}</td>\n    </tr>\n  </table>\n  <h3 style=\"margin-top: 20px; border-bottom: 1px solid #dee2e6; padding-bottom: 4px;\">Diagnosis</h3>\n  <div style=\"font-size: 13px;\">{{ doc.diagnosis or \"&mdash;\" }}</div>\n  <h3 style=\"margin-top: 16px; border-bottom: 1px solid #dee2e6; padding-bottom: 4px;\">Work Performed</h3>\n  <div style=\"font-size: 13px;\">{{ doc.work_performed or \"&mdash;\" }}</div>\n  {% if doc.spare_parts %}\n  <h3 style=\"margin-top: 16px; border-bottom: 1px solid #dee2e6; padding-bottom: 4px;\">Parts Used</h3>\n  <table style=\"width: 100%; border-collapse: collapse; font-size: 13px;\">\n    <thead><tr style=\"background: #f1f3f5;\"><th style=\"text-align: left; padding: 6px;\">Item</th><th style=\"text-align: right; padding: 6px;\">Qty</th><th style=\"text-align: right; padding: 6px;\">Rate</th><th style=\"text-align: right; padding: 6px;\">Amount</th></tr></thead>\n    <tbody>\n      {% for p in doc.spare_parts %}\n      <tr style=\"border-bottom: 1px solid #e9ecef;\"><td style=\"padding: 6px;\">{{ p.item_name or p.item_code }}</td><td style=\"text-align: right; padding: 6px;\">{{ p.qty }}</td><td style=\"text-align: right; padding: 6px;\">{{ frappe.utils.fmt_money(p.rate) }}</td><td style=\"text-align: right; padding: 6px;\">{{ frappe.utils.fmt_money(p.amount) }}</td></tr>\n      {% endfor %}\n      <tr><td colspan=\"3\" style=\"text-align: right; padding: 6px;\"><strong>Total</strong></td><td style=\"text-align: right; padding: 6px;\"><strong>{{ frappe.utils.fmt_money(doc.total_parts_amount) }}</strong></td></tr>\n    </tbody>\n  </table>\n  {% endif %}\n  <table style=\"width: 100%; margin-top: 40px; font-size: 13px;\">\n    <tr>\n      <td style=\"width: 50%;\"><div style=\"border-top: 1px solid #495057; width: 70%; padding-top: 4px;\">Technician Signature</div></td>\n      <td style=\"width: 50%;\"><div style=\"border-top: 1px solid #495057; width: 70%; padding-top: 4px;\">Customer Signature</div>{% if doc.customer_signature %}<img src=\"{{ doc.customer_signature }}\" style=\"max-height: 60px;\">{% endif %}</td>\n    </tr>\n  </table>\n</div>"
}