{
 "doctype": "DocType",
 "name": "Device",
 "module": "TechCare",
 "engine": "InnoDB",
 "naming_rule": "Expression (old style)",
 "autoname": "DEV-.#####",
 "title_field": "device_name",
 "fields": [
  {"fieldname": "device_name", "fieldtype": "Data", "label": "Device Name", "reqd": 1, "in_list_view": 1},
  {"fieldname": "device_category", "fieldtype": "Link", "label": "Category", "options": "Device Category", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
  {"fieldname": "serial_number", "fieldtype": "Data", "label": "Serial Number", "unique": 1, "in_list_view": 1},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_standard_filter": 1},
  {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1, "in_list_view": 1},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nIn Repair\nRetired", "default": "Active", "in_standard_filter": 1},
  {"fieldname": "details_section", "fieldtype": "Section Break", "label": "Details"},
  {"fieldname": "brand", "fieldtype": "Data", "label": "Brand"},
  {"fieldname": "model", "fieldtype": "Data", "label": "Model"},
  {"fieldname": "column_break_2", "fieldtype": "Column Break"},
  {"fieldname": "purchase_date", "fieldtype": "Date", "label": "Purchase Date"},
  {"fieldname": "warranty_expiry", "fieldtype": "Date", "label": "Warranty Expiry"},
  {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"}
 ],
 "permissions": [
  {"role": "Service Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Service Technician", "read": 1, "write": 1, "create": 1},
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
 ],
 "owner": "Administrator",
 "sort_field": "modified",
 "sort_order": "DESC"
}