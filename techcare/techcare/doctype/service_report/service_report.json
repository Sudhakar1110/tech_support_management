{
 "doctype": "DocType",
 "name": "Service Report",
 "module": "TechCare",
 "engine": "InnoDB",
 "naming_rule": "Expression (old style)",
 "autoname": "SRPT-.YYYY.-.#####",
 "title_field": "customer_name",
 "is_submittable": 1,
 "fields": [
  {"fieldname": "service_request", "fieldtype": "Link", "label": "Service Request", "options": "Service Request", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
  {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "fetch_from": "service_request.customer", "read_only": 1},
  {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1, "in_list_view": 1},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "device", "fieldtype": "Link", "label": "Device", "options": "Device", "fetch_from": "service_request.device", "read_only": 1, "in_list_view": 1},
  {"fieldname": "report_date", "fieldtype": "Date", "label": "Report Date", "default": "Today", "reqd": 1, "in_list_view": 1},
  {"fieldname": "technician", "fieldtype": "Link", "label": "Technician", "options": "Technician Profile"},
  {"fieldname": "work_section", "fieldtype": "Section Break", "label": "Work Details"},
  {"fieldname": "diagnosis", "fieldtype": "Text Editor", "label": "Diagnosis", "reqd": 1},
  {"fieldname": "work_performed", "fieldtype": "Text Editor", "label": "Work Performed", "reqd": 1},
  {"fieldname": "parts_section", "fieldtype": "Section Break", "label": "Spare Parts"},
  {"fieldname": "spare_parts", "fieldtype": "Table", "label": "Parts Used", "options": "Spare Part Usage"},
  {"fieldname": "total_parts_amount", "fieldtype": "Currency", "label": "Total Parts Amount", "read_only": 1},
  {"fieldname": "photos_section", "fieldtype": "Section Break", "label": "Photos"},
  {"fieldname": "photos", "fieldtype": "Table", "label": "Service Photos", "options": "Service Photo"},
  {"fieldname": "signoff_section", "fieldtype": "Section Break", "label": "Sign-off"},
  {"fieldname": "customer_signature", "fieldtype": "Signature", "label": "Customer Signature"},
  {"fieldname": "column_break_2", "fieldtype": "Column Break"},
  {"fieldname": "mark_request_resolved", "fieldtype": "Check", "label": "Mark Service Request as Resolved on Submit", "default": "1"}
 ],
 "permissions": [
  {"role": "Service Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
  {"role": "Service Technician", "read": 1, "write": 1, "create": 1, "submit": 1},
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1}
 ],
 "owner": "Administrator",
 "sort_field": "modified",
 "sort_order": "DESC"
}