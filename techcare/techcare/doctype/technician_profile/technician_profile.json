{
 "doctype": "DocType",
 "name": "Technician Profile",
 "module": "TechCare",
 "engine": "InnoDB",
 "naming_rule": "Expression (old style)",
 "autoname": "TECH-.####",
 "title_field": "technician_name",
 "fields": [
  {"fieldname": "technician_name", "fieldtype": "Data", "label": "Technician Name", "reqd": 1, "in_list_view": 1},
  {"fieldname": "user", "fieldtype": "Link", "label": "User Account", "options": "User", "unique": 1, "in_list_view": 1},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "mobile", "fieldtype": "Data", "label": "Mobile", "options": "Phone"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nOn Leave\nInactive", "default": "Active", "in_list_view": 1, "in_standard_filter": 1},
  {"fieldname": "skills_section", "fieldtype": "Section Break", "label": "Skills & Certifications"},
  {"fieldname": "skills", "fieldtype": "Table", "label": "Skills", "options": "Technician Skill"},
  {"fieldname": "certifications", "fieldtype": "Table", "label": "Certifications", "options": "Technician Certification"}
 ],
 "permissions": [
  {"role": "Service Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Service Technician", "read": 1},
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
 ],
 "owner": "Administrator",
 "sort_field": "modified",
 "sort_order": "DESC"
}